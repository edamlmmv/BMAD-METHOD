{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BMAD Capability Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "metadata",
    "capability",
    "status",
    "inputs",
    "artifacts",
    "boundaries",
    "acceptanceCriteria",
    "humanReview"
  ],
  "properties": {
    "kind": {
      "const": "bmad-capability-pack"
    },
    "schemaVersion": {
      "const": 1
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "generatorVersion"],
      "properties": {
        "source": {
          "const": "capability-pack-forge"
        },
        "generatorVersion": {
          "const": 1
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "summary"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packMode", "verificationStatus", "label", "summary"],
      "properties": {
        "packMode": {
          "enum": ["verifier-ready", "draft-authoring"]
        },
        "verificationStatus": {
          "enum": ["ready", "draft_no_contract"]
        },
        "label": {
          "enum": ["Ready", "Draft"]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "path", "role", "sourceType", "sha256"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "sourceType": {
            "enum": ["context7", "local_docs", "manual_contract", "repo_template", "other"]
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "role"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "statement"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "statement": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "humanReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "nextSteps"],
      "properties": {
        "required": {
          "const": true
        },
        "nextSteps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
